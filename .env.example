# .env.example — copy to .env (which is gitignored)
#
# IMPORTANT: do NOT set ANTHROPIC_API_KEY.
# This project authenticates the Claude Agent SDK through the Max plan via the
# Claude Code CLI (`claude login`). If ANTHROPIC_API_KEY is set, the SDK will use
# the API and bill pay-as-you-go instead of your plan credit. Leave it unset.

# --- App config (safe to set) ---
# Confidence below which a grade is routed to the teacher review queue (0..1)
TRIAGE_CONFIDENCE_THRESHOLD=0.7

# Number of samples for self-consistency confidence scoring
SELF_CONSISTENCY_K=5

# Max autonomous escalations before handing off to the teacher
MAX_ESCALATIONS=2

# SQLite path
DB_PATH=data/cache.sqlite

# Math topic for the first build (keep scope to one topic)
TOPIC=linear_equations
